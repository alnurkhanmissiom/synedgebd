---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh" description= "SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online.">
    
    
    <!-- --- Main Content --- -->
    <main class="contact-section">
        <div class="container">
            
            <!-- --- Left Info Column --- -->
            <div class="contact-info">
                <h1>Get in touch whenever you're ready</h1>
                <p class="subtext">We would love to learn more about your project idea. Contact us and we will get back to you within a few business hours.</p>

                <div class="office-location">
                    <h3>Head office:</h3>
                    <div class="location">Amsterdam, Netherlands <span>&larr; &rarr;</span></div>
                    <p class="address">Keizersgracht 452,<br>Amsterdam, Netherlands, 1016GD</p>
                </div>

                <div class="other-locations">
                    <span>🇳🇱 Netherlands</span>
                    <span>🇸🇪 Sweden</span>
                    <span>🇵🇱 Poland</span>
                    <span>🇺🇦 Ukraine</span>
                    <span>🇨🇦 Canada</span>
                </div>

                <div class="contact-details">
                    <div class="contact-item">
                        <!-- You can replace the emoji with a Font Awesome icon if you prefer -->
                        <div class="icon">📞</div> 
                        <div class="details">
                            <span class="value">+(880)1711-032-586</span>
                        </div>
                    </div>
                    <div class="contact-item">
                        <!-- Example: <div class="icon"><i class="fas fa-envelope"></i></div> -->
                        <div class="icon">✉️</div>
                        <div class="details">
                            <span class="label">Send us an email</span>
                            <span class="value">info@synedgebd.com</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- --- Right Form Column --- -->
            <div class="contact-form-container">
                <div class="form-tabs">
                    <span class="tab active" data-tab="project">Discuss a project</span>
                    <span class="tab" data-tab="cv">Send CV</span>
                </div>

                <!-- Project Form Panel -->
                <div id="project" class="form-panel active">
                    <form>
                        <div class="form-group">
                            <label for="full-name">Full Name <span>*</span></label>
                            <input type="text" id="full-name" placeholder="Full Name">
                        </div>
                        <div class="form-group">
                            <label for="company">Company <span>*</span></label>
                            <input type="text" id="company" placeholder="Company">
                        </div>
                        <div class="form-group">
                            <label for="email">E-mail <span>*</span></label>
                            <input type="email" id="email" placeholder="j.alex.walker@domain.com">
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone</label>
                            <input type="tel" id="phone" placeholder="+1 403 879 94 95">
                        </div>
                        <div class="form-group">
                            <label for="project-details">Tell us about your project</label>
                            <textarea id="project-details" rows="4"></textarea>
                        </div>
                        
                        <!-- Example: <a href="#" class="attach-files"><i class="fas fa-paperclip"></i> Attach files</a><br> -->
                        <a href="#" class="attach-files">📎 Attach files</a><br>

                        <button type="submit" class="btn-submit">Submit &rarr;</button>
                    </form>
                </div>

                <!-- CV Form Panel -->
                <div id="cv" class="form-panel">
                    <p>CV submission form would go here.</p>
                    <form>
                        <div class="form-group">
                            <label for="full-name">Full Name <span>*</span></label>
                            <input type="text" id="full-name" placeholder="Full Name">
                        </div>
                        <div class="form-group">
                            <label for="Position">Position <span>*</span></label>
                            <input type="text" id="position" placeholder="Position">
                        </div>
                        <div class="form-group">
                            <label for="email">E-mail <span>*</span></label>
                            <input type="email" id="email" placeholder="j.alex.walker@domain.com">
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone</label>
                            <input type="tel" id="phone" placeholder="+1 403 879 94 95">
                        </div>
                        <div class="form-group">
                            <label for="project-details">Tell us about your project</label>
                            <textarea id="project-details" rows="4"></textarea>
                        </div>
                        
                        <!-- Example: <a href="#" class="attach-files"><i class="fas fa-paperclip"></i> Attach files</a><br> -->
                        <a href="#" class="attach-files">📎 Attach files</a><br>

                        <button type="submit" class="btn-submit">Submit &rarr;</button>
                    </form>
                </div>

                    <!-- You would add the form fields for CV submission here -->
                </div>
            </div>

        </div>
    </main>

</Layout>