---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh" description= "SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online.">
       <!-- --- Hero Section: Transform your business --- -->
    <section class="hero-company">
        <div class="container">
            <div class="hero-content">
                <h1>Transform your business with web, SEO, and creative solutions</h1>
                <p>SynEdge BD helps businesses grow with professional web development, search engine optimization, digital marketing, and creative design services.</p>
                <a href="#services" class="btn-primary">Explore Services <span>&darr;</span></a>
            </div>
            <div class="hero-visual">
                <img src="https://placehold.co/600x400/1a1a1a/ffc107?text=Digital+Transformation" alt="Abstract digital transformation visual">
            </div>
        </div>
    </section>

    <!-- --- Services Overview Section --- -->
    <section class="services-overview" id="services">
        <div class="container">
            <h2>Our Services</h2>
            <div class="services-grid">
                <!-- Service 1: Web Development -->
                <div class="service-card">
                    <i class="fas fa-code"></i>
                    <h4>Web Development</h4>
                    <p>Custom websites, web apps, and eCommerce solutions optimized for performance and scalability.</p>
                </div>
                <!-- Service 2: SEO Optimization -->
                <div class="service-card">
                    <i class="fas fa-chart-line"></i>
                    <h4>SEO Optimization</h4>
                    <p>Boost your visibility and reach the right audience through proven SEO strategies and analytics.</p>
                </div>
                <!-- Service 3: Digital Marketing -->
                <div class="service-card">
                    <i class="fas fa-bullhorn"></i>
                    <h4>Digital Marketing</h4>
                    <p>Data-driven campaigns across social, search, and email to attract and convert more customers.</p>
                </div>
                <!-- Service 4: Creative Services -->
                <div class="service-card">
                    <i class="fas fa-palette"></i>
                    <h4>Creative Services</h4>
                    <p>Branding, graphics, and UI/UX design that deliver stunning visuals and engaging experiences.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- --- About SynEdge BD Section --- -->
    <section class="about-us">
        <div class="container">
            <div class="about-content">
                <h2>About SynEdge BD</h2>
                <p>SynEdge BD is a **Bangladesh-based digital agency** dedicated to delivering impactful web and marketing solutions. Our team of experts merges **technology and creativity** to help businesses not just exist online, but truly expand their reach and dominate their market. We pride ourselves on a collaborative approach, ensuring every solution is tailored and drives tangible results for our clients globally.</p>
                <a href="#" class="btn-secondary">Meet the Team</a>
            </div>
            <div class="about-stats">
                <div class="stat-card"><span>5+</span><p>Years in Business</p></div>
                <div class="stat-card"><span>150+</span><p>Successful Projects</p></div>
                <div class="stat-card"><span>95%</span><p>Client Satisfaction</p></div>
            </div>
        </div>
    </section>

    <!-- --- CTA Section --- -->
    <section class="cta-company">
        <div class="container">
            <h2>Ready to Expand Your Digital Footprint?</h2>
            <p>Let SynEdge BD provide the edge you need in web development, SEO, marketing, and creative design.</p>
            <a href="#" class="btn-primary">Start a Project Today</a>
        </div>
    </section>
</Layout>