---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh"
  description="SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online."
>
  <!-- ===== Hero Section ===== -->
  <section class="relative min-h-screen overflow-hidden bg-slate-950 pt-32 sm:pt-36">
    <!-- Background -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.16),transparent_22%),radial-gradient(circle_at_top_right,rgba(139,92,246,0.22),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(245,158,11,0.10),transparent_22%),linear-gradient(135deg,#312e81_0%,#4c1d95_42%,#020617_100%)]"></div>
    <div class="absolute inset-0 opacity-[0.08] bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:42px_42px]"></div>

    <!-- 3D animated background -->
    <div class="pointer-events-none absolute -left-20 top-24 h-80 w-80 animate-pulse rounded-full bg-cyan-400/20 blur-3xl"></div>
    <div class="pointer-events-none absolute right-0 top-16 h-[28rem] w-[28rem] animate-pulse rounded-full bg-violet-500/20 blur-3xl"></div>

    <div class="relative z-10 mx-auto grid min-h-[calc(100vh-120px)] max-w-7xl items-center gap-14 px-4 pb-20 sm:px-6 lg:grid-cols-2 lg:px-8">
      <!-- Left Content -->
      <div class="order-2 text-center lg:order-1 lg:text-left">
        <span class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-semibold text-cyan-100 shadow-lg backdrop-blur-md sm:text-sm">
          SMART WEB · SEO · CREATIVE GROWTH SYSTEM
        </span>

        <h1 class="mx-auto mt-6 max-w-4xl text-4xl font-extrabold leading-[1.04] sm:text-5xl md:text-6xl xl:mx-0 xl:text-7xl">
          Transform Your
          <span class="bg-gradient-to-r from-white via-cyan-200 to-fuchsia-300 bg-clip-text text-transparent">
            Digital Presence
          </span>
          With 3D-Level Impact
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-slate-200/85 sm:text-lg md:text-xl xl:mx-0">
          SynEdge BD empowers brands to grow through data-driven web development, SEO,
          marketing, and creative excellence — wrapped in a premium modern experience.
        </p>

        <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row lg:justify-start">
          <a
            href="#services"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-bold text-slate-900 shadow-xl transition duration-300 hover:scale-105"
          >
            <span>Explore Services</span>
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-violet-100 text-violet-700">
              ↘
            </span>
          </a>

          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-7 py-3.5 text-base font-semibold text-white transition duration-300 hover:border-cyan-300/50 hover:bg-white/15"
          >
            Start Your Project
          </a>
        </div>

        <div class="mx-auto mt-12 grid max-w-xl grid-cols-1 gap-4 sm:grid-cols-3 sm:gap-6 lg:mx-0">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center lg:text-left">
            <div class="text-3xl font-extrabold md:text-4xl">90k</div>
            <p class="mt-2 text-sm text-slate-300 sm:text-base">Happy Clients</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center lg:text-left">
            <div class="text-3xl font-extrabold md:text-4xl">650+</div>
            <p class="mt-2 text-sm text-slate-300 sm:text-base">Projects Delivered</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center lg:text-left">
            <div class="text-3xl font-extrabold md:text-4xl">85+</div>
            <p class="mt-2 text-sm text-slate-300 sm:text-base">Growth Partners</p>
          </div>
        </div>
      </div>

      <!-- Right Visual -->
      <div class="order-1 flex justify-center lg:order-2">
        <div class="relative h-[420px] w-full max-w-[460px] sm:h-[420px]">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="absolute h-[320px] w-[320px] rounded-full border border-cyan-400/20 animate-[spin_28s_linear_infinite] sm:h-[440px] sm:w-[440px]"></div>
            <div class="absolute h-[280px] w-[280px] rounded-full border border-violet-400/20 animate-[spin_20s_linear_infinite_reverse] sm:h-[390px] sm:w-[390px]"></div>
            <div class="absolute h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle_at_30%_30%,rgba(34,211,238,0.9),rgba(59,130,246,0.55)_28%,rgba(76,29,149,0.72)_58%,rgba(2,6,23,0.96)_78%)] shadow-[0_0_80px_rgba(34,211,238,0.18)] sm:h-[340px] sm:w-[340px]"></div>
            <div class="absolute h-[300px] w-[300px] rounded-full bg-[conic-gradient(from_90deg,rgba(34,211,238,0.25),transparent,rgba(168,85,247,0.26),transparent,rgba(245,158,11,0.18),transparent)] blur-2xl sm:h-[380px] sm:w-[380px]"></div>
          </div>

          <div class="absolute left-1/2 top-1/2 h-4 w-4 animate-[spin_16s_linear_infinite] rounded-full bg-white shadow-[0_0_30px_rgba(255,255,255,0.7)]"></div>

          <div class="absolute top-10 right-0 rounded-3xl border border-white/10 bg-white/10 p-4 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md sm:p-5">
            <div class="text-xs uppercase tracking-[0.2em] text-cyan-300">Smart Stack</div>
            <div class="mt-2 text-lg font-bold">Web · SEO · Marketing</div>
          </div>
          <div class="absolute bottom-12 left-0 rounded-3xl border border-white/10 bg-white/10 p-5 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md">
            <div class="text-3xl font-bold">24/7</div>
            <div class="mt-1 text-slate-300">Performance Monitoring</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Services Overview ===== -->
  <section id="services" class="relative bg-slate-950 py-24 px-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_center,rgba(34,211,238,0.07),transparent_25%)]"></div>

    <div class="relative mx-auto max-w-7xl">
      <div class="mb-16 text-center">
        <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-300">
          OUR SERVICES
        </span>
        <h2 class="mt-5 text-4xl font-bold md:text-5xl">Our Core Service Pillars</h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-slate-400 sm:text-lg">
          A premium digital stack designed to improve visibility, performance, and business growth.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2">
        <!-- Web Development -->
        <div class="group rounded-3xl border border-white/10 bg-white/5 p-8 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)] md:p-10">
          <div class="mb-5 inline-flex rounded-2xl bg-cyan-400/15 p-4 text-cyan-300">
            <i class="ri-code-s-slash-line text-3xl"></i>
          </div>
          <h3 class="mb-3 text-3xl font-bold">Web Development & Technology</h3>
          <p class="mb-5 text-slate-400 leading-8">
            We craft high-performance, responsive, and secure web platforms that drive conversions and enhance user experience.
          </p>
          <ul class="space-y-2 text-slate-300">
            <li>⚡ Custom Websites & Web Apps</li>
            <li>🛍️ E-commerce (Shopify, WooCommerce, Custom)</li>
            <li>🔧 CMS Integration & Headless Architecture</li>
            <li>🚀 Performance Optimization</li>
          </ul>
          <a
            href="#contact"
            class="mt-6 inline-block rounded-full bg-cyan-400 px-6 py-2 font-semibold text-slate-950 transition-transform hover:scale-105"
          >
            Start a Web Project
          </a>
        </div>

        <!-- SEO -->
        <div class="group rounded-3xl border border-white/10 bg-white/5 p-8 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)] md:p-10">
          <div class="mb-5 inline-flex rounded-2xl bg-violet-400/15 p-4 text-violet-300">
            <i class="ri-search-eye-line text-3xl"></i>
          </div>
          <h3 class="mb-3 text-3xl font-bold">Search Engine Optimization (SEO)</h3>
          <p class="mb-5 text-slate-400 leading-8">
            We combine data, strategy, and technology to maximize visibility and ensure long-term organic growth.
          </p>
          <ul class="space-y-2 text-slate-300">
            <li>🔍 Technical & On-Page SEO Audits</li>
            <li>📝 Content Strategy & Keyword Optimization</li>
            <li>🔗 Link Building & Domain Authority</li>
            <li>📍 Local SEO & Google Maps Ranking</li>
          </ul>
          <a
            href="#contact"
            class="mt-6 inline-block rounded-full bg-violet-400 px-6 py-2 font-semibold text-white transition-transform hover:scale-105"
          >
            Request SEO Audit
          </a>
        </div>

        <!-- Marketing -->
        <div class="group rounded-3xl border border-white/10 bg-white/5 p-8 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)] md:p-10">
          <div class="mb-5 inline-flex rounded-2xl bg-amber-400/15 p-4 text-amber-300">
            <i class="ri-megaphone-line text-3xl"></i>
          </div>
          <h3 class="mb-3 text-3xl font-bold">Digital Marketing Campaigns</h3>
          <p class="mb-5 text-slate-400 leading-8">
            Execute powerful campaigns that generate leads and increase conversions across every digital channel.
          </p>
          <ul class="space-y-2 text-slate-300">
            <li>🎯 PPC & Google Ads Management</li>
            <li>📱 Social Media Advertising & Strategy</li>
            <li>📧 Email & Automation Campaigns</li>
            <li>📊 Analytics, CRO & Reporting</li>
          </ul>
          <a
            href="#contact"
            class="mt-6 inline-block rounded-full bg-amber-400 px-6 py-2 font-semibold text-slate-950 transition-transform hover:scale-105"
          >
            See Marketing Plans
          </a>
        </div>

        <!-- Creative -->
        <div class="group rounded-3xl border border-white/10 bg-white/5 p-8 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)] md:p-10">
          <div class="mb-5 inline-flex rounded-2xl bg-fuchsia-400/15 p-4 text-fuchsia-300">
            <i class="ri-palette-line text-3xl"></i>
          </div>
          <h3 class="mb-3 text-3xl font-bold">Creative Design & Branding</h3>
          <p class="mb-5 text-slate-400 leading-8">
            Creativity that inspires. We build visual experiences and brand identities that leave a lasting impression.
          </p>
          <ul class="space-y-2 text-slate-300">
            <li>🎨 Brand Strategy & Identity Design</li>
            <li>🧠 UI/UX Design & Wireframing</li>
            <li>🖼️ Marketing Collateral & Graphic Design</li>
            <li>🎬 Motion Graphics & Video Content</li>
          </ul>
          <a
            href="#contact"
            class="mt-6 inline-block rounded-full bg-fuchsia-400 px-6 py-2 font-semibold text-white transition-transform hover:scale-105"
          >
            View Portfolio
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== About Section ===== -->
  <section id="about" class="bg-[linear-gradient(180deg,#020617_0%,#0f172a_100%)] py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="inline-flex rounded-full border border-violet-400/20 bg-violet-400/10 px-4 py-2 text-sm font-semibold text-violet-300">
          ABOUT SYNEDGE BD
        </span>
        <h2 class="mt-5 text-4xl font-bold leading-tight md:text-5xl">
          A Bangladesh-based digital agency focused on performance, clarity, and measurable growth.
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-400">
          We combine strategy, design, and technology to help businesses expand their reach online.
          Every solution is built for speed, scalability, and real results.
        </p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
            <div class="text-2xl text-cyan-300">
              <i class="ri-rocket-2-line"></i>
            </div>
            <h3 class="mt-3 text-xl font-bold">Fast Execution</h3>
            <p class="mt-2 text-slate-400">
              Lean production, strong systems, and clear milestones.
            </p>
          </div>

          <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
            <div class="text-2xl text-amber-300">
              <i class="ri-bar-chart-box-line"></i>
            </div>
            <h3 class="mt-3 text-xl font-bold">Growth Driven</h3>
            <p class="mt-2 text-slate-400">
              Everything we build is aligned with outcomes and KPIs.
            </p>
          </div>
        </div>
      </div>

      <div class="relative h-[420px] sm:h-[500px]">
        <div class="absolute inset-0 rounded-[2rem] border border-white/10 bg-gradient-to-br from-cyan-400/10 via-violet-500/10 to-amber-400/10"></div>
        <div class="absolute inset-8 overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900/70 shadow-[0_25px_60px_rgba(2,6,23,0.35)]">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.18),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.18),transparent_30%)]"></div>
          <div class="absolute left-1/2 top-1/2 h-52 w-52 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle_at_30%_30%,rgba(34,211,238,0.9),rgba(59,130,246,0.5)_30%,rgba(76,29,149,0.82)_65%,rgba(2,6,23,0.96)_80%)] shadow-[0_0_70px_rgba(34,211,238,0.18)]"></div>
          <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full border border-cyan-400/20 animate-[spin_28s_linear_infinite]"></div>

          <div class="absolute inset-x-10 bottom-10 rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-md">
            <div class="text-sm uppercase tracking-[0.2em] text-cyan-300">Performance Snapshot</div>
            <div class="mt-3 grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold">4X</div>
                <div class="text-sm text-slate-400">Traffic</div>
              </div>
              <div>
                <div class="text-2xl font-bold">2.8X</div>
                <div class="text-sm text-slate-400">Leads</div>
              </div>
              <div>
                <div class="text-2xl font-bold">98%</div>
                <div class="text-sm text-slate-400">Speed</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Process Section ===== -->
  <section id="process" class="bg-slate-950 py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16 text-center">
        <span class="inline-flex rounded-full border border-amber-400/20 bg-amber-400/10 px-4 py-2 text-sm font-semibold text-amber-300">
          HOW WE WORK
        </span>
        <h2 class="mt-5 text-4xl font-bold md:text-5xl">
          A clear process, built like a modern product pipeline
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <div class="text-4xl font-black text-cyan-300">01</div>
          <h3 class="mt-4 text-xl font-bold">Discover</h3>
          <p class="mt-3 text-slate-400">We map goals, users, bottlenecks, and opportunities.</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <div class="text-4xl font-black text-violet-300">02</div>
          <h3 class="mt-4 text-xl font-bold">Design</h3>
          <p class="mt-3 text-slate-400">We create visual systems and conversion-focused experiences.</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <div class="text-4xl font-black text-amber-300">03</div>
          <h3 class="mt-4 text-xl font-bold">Develop</h3>
          <p class="mt-3 text-slate-400">We build fast, scalable, and production-ready digital products.</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <div class="text-4xl font-black text-fuchsia-300">04</div>
          <h3 class="mt-4 text-xl font-bold">Grow</h3>
          <p class="mt-3 text-slate-400">We optimize with SEO, analytics, and continuous marketing loops.</p>
        </div>
      </div>
    </div>
  </section>


<section id="team" class="relative overflow-hidden bg-slate-950 py-20 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14 sm:mb-16">
      <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-300">
        OUR TEAM
      </span>
      <h2 class="mt-5 text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Meet Our Expert Team
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-7 text-slate-400">
        A creative and performance-driven team building modern digital experiences for growing brands.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 xl:grid-cols-3">
      
      <!-- Card 1 -->
      <div class="group relative mx-auto w-full max-w-[420px] rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-500 hover:-translate-y-3 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)]">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></div>
          <img
            src="/team-1.jpg"
            alt="Alnur Khan Missiom"
            class="h-[320px] sm:h-[350px] md:h-[380px] w-full object-cover object-top transition duration-700 group-hover:scale-110"
          />
          <div class="absolute -left-16 top-0 h-full w-24 rotate-12 bg-white/20 blur-2xl opacity-0 transition duration-700 group-hover:translate-x-[340px] group-hover:opacity-100"></div>
        </div>

        <div class="relative -mt-14 sm:-mt-16 z-20 mx-3 sm:mx-4 h-[190px] sm:h-[200px] rounded-[1.5rem] sm:rounded-[1.7rem] border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(91,33,182,0.96),rgba(37,99,235,0.96))] p-5 sm:p-6 text-center shadow-xl transition duration-500 group-hover:shadow-[0_20px_60px_rgba(99,102,241,0.35)] flex flex-col justify-between">
          <div class="flex-1 flex flex-col items-center justify-center">
            <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight">Alnur Khan </h3>
            <p class="mt-3 text-xs sm:text-sm uppercase tracking-[0.18em] text-cyan-100">Web Designer</p>
          </div>

          <div class="mt-5 flex justify-center gap-3 opacity-100 sm:opacity-0 translate-y-0 sm:translate-y-4 transition duration-500 group-hover:opacity-100 group-hover:translate-y-0">
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#1877F2] transition">
              <i class="ri-facebook-fill"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-cyan-500 transition">
              <i class="ri-twitter-x-line"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#E1306C] transition">
              <i class="ri-instagram-line"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="group relative mx-auto w-full max-w-[420px] rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-500 hover:-translate-y-3 hover:border-violet-400/40 hover:shadow-[0_20px_60px_rgba(139,92,246,0.20)]">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></div>
          <img
            src="/team-2.jpg"
            alt="Iftakharul Alam"
            class="h-[320px] sm:h-[350px] md:h-[380px] w-full object-cover object-top transition duration-700 group-hover:scale-110"
          />
          <div class="absolute -left-16 top-0 h-full w-24 rotate-12 bg-white/20 blur-2xl opacity-0 transition duration-700 group-hover:translate-x-[340px] group-hover:opacity-100"></div>
        </div>

        <div class="relative -mt-14 sm:-mt-16 z-20 mx-3 sm:mx-4 h-[190px] sm:h-[200px] rounded-[1.5rem] sm:rounded-[1.7rem] border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(91,33,182,0.96),rgba(37,99,235,0.96))] p-5 sm:p-6 text-center shadow-xl transition duration-500 group-hover:shadow-[0_20px_60px_rgba(99,102,241,0.35)] flex flex-col justify-between">
          <div class="flex-1 flex flex-col items-center justify-center">
            <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight">Iftakharul Alam</h3>
            <p class="mt-3 text-xs sm:text-sm uppercase tracking-[0.18em] text-cyan-100">CEO & Founder</p>
          </div>

          <div class="mt-5 flex justify-center gap-3 opacity-100 sm:opacity-0 translate-y-0 sm:translate-y-4 transition duration-500 group-hover:opacity-100 group-hover:translate-y-0">
