---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh" description= "SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online.">
    <!-- ===== Hero Section ===== -->
  <section class="pt-40 pb-24 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-black via-gray-900 to-black opacity-90"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
        Transform Your <span class="text-primary">Digital Presence</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10">
        SynEdge BD empowers brands to grow through data-driven strategies in Web, SEO, Marketing, and Creative excellence.
      </p>
      <a href="#services" class="inline-block bg-primary text-black font-bold px-8 py-3 rounded-full hover:scale-105 transition-transform">
        Explore Services ↓
      </a>
    </div>
  </section>
  <!-- ===== Services Overview ===== -->
  <section id="services" class="py-24 px-6 max-w-7xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-16">Our Core Service Pillars</h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-12">

      <!-- Web Development -->
      <div class="service-card bg-gray-900 p-10 rounded-2xl fade-up">
        <div class="mb-5">
          <i data-lucide="code-2" class="w-12 h-12 text-primary"></i>
        </div>
        <h3 class="text-3xl font-bold mb-3">Web Development & Technology</h3>
        <p class="text-gray-400 mb-5">
          We craft high-performance, responsive, and secure web platforms that drive conversions and enhance user experience.
        </p>
        <ul class="space-y-2 text-gray-400">
          <li>⚡ Custom Websites & Web Apps</li>
          <li>🛍️ E-commerce (Shopify, WooCommerce, Custom)</li>
          <li>🔧 CMS Integration & Headless Architecture</li>
          <li>🚀 Performance Optimization</li>
        </ul>
        <a href="#" class="inline-block mt-6 bg-primary text-black px-6 py-2 rounded-full font-semibold hover:scale-105 transition-transform">Start a Web Project</a>
      </div>

      <!-- SEO Optimization -->
      <div class="service-card bg-gray-900 p-10 rounded-2xl fade-up">
        <div class="mb-5">
          <i data-lucide="search" class="w-12 h-12 text-primary"></i>
        </div>
        <h3 class="text-3xl font-bold mb-3">Search Engine Optimization (SEO)</h3>
        <p class="text-gray-400 mb-5">
          We combine data, strategy, and technology to maximize visibility and ensure long-term organic growth.
        </p>
        <ul class="space-y-2 text-gray-400">
          <li>🔍 Technical & On-Page SEO Audits</li>
          <li>📝 Content Strategy & Keyword Optimization</li>
          <li>🔗 Link Building & Domain Authority</li>
          <li>📍 Local SEO & Google Maps Ranking</li>
        </ul>
        <a href="#" class="inline-block mt-6 bg-primary text-black px-6 py-2 rounded-full font-semibold hover:scale-105 transition-transform">Request SEO Audit</a>
      </div>

      <!-- Digital Marketing -->
      <div class="service-card bg-gray-900 p-10 rounded-2xl fade-up">
        <div class="mb-5">
          <i data-lucide="megaphone" class="w-12 h-12 text-primary"></i>
        </div>
        <h3 class="text-3xl font-bold mb-3">Digital Marketing Campaigns</h3>
        <p class="text-gray-400 mb-5">
          Execute powerful campaigns that generate leads and increase conversions across every digital channel.
        </p>
        <ul class="space-y-2 text-gray-400">
          <li>🎯 PPC & Google Ads Management</li>
          <li>📱 Social Media Advertising & Strategy</li>
          <li>📧 Email & Automation Campaigns</li>
          <li>📊 Analytics, CRO & Reporting</li>
        </ul>
        <a href="#" class="inline-block mt-6 bg-primary text-black px-6 py-2 rounded-full font-semibold hover:scale-105 transition-transform">See Marketing Plans</a>
      </div>

      <!-- Creative & Branding -->
      <div class="service-card bg-gray-900 p-10 rounded-2xl fade-up">
        <div class="mb-5">
          <i data-lucide="palette" class="w-12 h-12 text-primary"></i>
        </div>
        <h3 class="text-3xl font-bold mb-3">Creative Design & Branding</h3>
        <p class="text-gray-400 mb-5">
          Creativity that inspires. We build visual experiences and brand identities that leave a lasting impression.
        </p>
        <ul class="space-y-2 text-gray-400">
          <li>🎨 Brand Strategy & Identity Design</li>
          <li>🧠 UI/UX Design & Wireframing</li>
          <li>🖼️ Marketing Collateral & Graphic Design</li>
          <li>🎬 Motion Graphics & Video Content</li>
        </ul>
        <a href="#" class="inline-block mt-6 bg-primary text-black px-6 py-2 rounded-full font-semibold hover:scale-105 transition-transform">View Portfolio</a>
      </div>
    </div>
  </section>
  <!-- ===== CTA Section ===== -->
  <section class="py-24 text-center bg-gray-950">
    <h2 class="text-4xl font-bold mb-4">Ready to Take Your Business to the Next Level?</h2>
    <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
      Let’s collaborate to build something extraordinary — from stunning web platforms to impactful digital strategies.
    </p>
    <a href="contact-us.html" class="inline-block bg-primary text-black text-lg px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform">
      Start Your Project
    </a>
  </section>
  </Layout>