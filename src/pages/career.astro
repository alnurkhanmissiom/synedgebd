---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh" description= "SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online.">
   
   <canvas id="header-canvas" />
    <!-- Hero Section -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-4 md:px-8 bg-transparent pt-32">
    <h1 class="text-5xl md:text-6xl font-bold mb-4">Join Our <span class="text-blue-500">Creative Team</span></h1>
    <p class="max-w-2xl text-gray-300 text-lg mb-8">
      At SynEdge BD, we believe innovation begins with people. Join a passionate team shaping the digital future.
    </p>
    <a href="#open-positions" class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-full font-semibold transition-all">Explore Openings</a>
  </section>

  <!-- Why Join Us -->
  <section class="py-24 bg-black/60 backdrop-blur-sm text-center px-4 md:px-8">
    <h2 class="text-3xl md:text-4xl font-bold mb-8">Why Join <span class="text-blue-500">SynEdge BD</span>?</h2>
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-10 text-gray-300">
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <i data-lucide="cpu" class="w-10 h-10 mx-auto text-blue-400 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">Cutting-Edge Projects</h3>
        <p>Work with emerging technologies in AI, automation, and industrial systems.</p>
      </div>
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <i data-lucide="users" class="w-10 h-10 mx-auto text-blue-400 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">Collaborative Culture</h3>
        <p>We value creativity, curiosity, and open collaboration among teammates.</p>
      </div>
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <i data-lucide="rocket" class="w-10 h-10 mx-auto text-blue-400 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">Career Growth</h3>
        <p>Continuous learning opportunities, mentorship, and professional development.</p>
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section id="open-positions" class="py-24 bg-black/40 backdrop-blur-sm text-center px-4 md:px-8">
    <h2 class="text-3xl md:text-4xl font-bold mb-8">Current Openings</h2>
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-10 text-gray-300">
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <h3 class="text-xl font-semibold mb-2">Frontend Developer</h3>
        <p>React, TailwindCSS, and modern JS frameworks experience required.</p>
        <a href="mailto:hr@synedgebd.com" class="inline-block mt-4 text-blue-400 hover:text-blue-500 font-semibold">Apply Now →</a>
      </div>
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <h3 class="text-xl font-semibold mb-2">UI/UX Designer</h3>
        <p>Design clean, modern interfaces with Figma or Adobe XD.</p>
        <a href="mailto:hr@synedgebd.com" class="inline-block mt-4 text-blue-400 hover:text-blue-500 font-semibold">Apply Now →</a>
      </div>
      <div class="p-6 rounded-2xl bg-gray-800/50 hover:bg-gray-700/70 transition">
        <h3 class="text-xl font-semibold mb-2">Digital Marketing Executive</h3>
        <p>SEO, Google Ads, and Social Media expertise preferred.</p>
        <a href="mailto:hr@synedgebd.com" class="inline-block mt-4 text-blue-400 hover:text-blue-500 font-semibold">Apply Now →</a>
      </div>
    </div>
  </section>




<section id="team" class="relative overflow-hidden bg-slate-950 py-20 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14 sm:mb-16">
      <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-300">
        OUR TEAM
      </span>
      <h2 class="mt-5 text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Meet Our Expert Team
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-7 text-slate-400">
        A creative and performance-driven team building modern digital experiences for growing brands.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 xl:grid-cols-3">
      
      <!-- Card 1 -->
      <div class="group relative mx-auto w-full max-w-[420px] rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-500 hover:-translate-y-3 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)]">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></div>
          <img
            src="/team-1.jpg"
            alt="Alnur Khan Missiom"
            class="h-[320px] sm:h-[350px] md:h-[380px] w-full object-cover object-top transition duration-700 group-hover:scale-110"
          />
          <div class="absolute -left-16 top-0 h-full w-24 rotate-12 bg-white/20 blur-2xl opacity-0 transition duration-700 group-hover:translate-x-[340px] group-hover:opacity-100"></div>
        </div>

        <div class="relative -mt-14 sm:-mt-16 z-20 mx-3 sm:mx-4 h-[190px] sm:h-[200px] rounded-[1.5rem] sm:rounded-[1.7rem] border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(91,33,182,0.96),rgba(37,99,235,0.96))] p-5 sm:p-6 text-center shadow-xl transition duration-500 group-hover:shadow-[0_20px_60px_rgba(99,102,241,0.35)] flex flex-col justify-between">
          <div class="flex-1 flex flex-col items-center justify-center">
            <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight">Alnur Khan Missiom</h3>
            <p class="mt-3 text-xs sm:text-sm uppercase tracking-[0.18em] text-cyan-100">Web Designer</p>
          </div>

          <div class="mt-5 flex justify-center gap-3 opacity-100 sm:opacity-0 translate-y-0 sm:translate-y-4 transition duration-500 group-hover:opacity-100 group-hover:translate-y-0">
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#1877F2] transition">
              <i class="ri-facebook-fill"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-cyan-500 transition">
              <i class="ri-twitter-x-line"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#E1306C] transition">
              <i class="ri-instagram-line"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="group relative mx-auto w-full max-w-[420px] rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-500 hover:-translate-y-3 hover:border-violet-400/40 hover:shadow-[0_20px_60px_rgba(139,92,246,0.20)]">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></div>
          <img
            src="/team-2.jpg"
            alt="Iftakharul Alam"
            class="h-[320px] sm:h-[350px] md:h-[380px] w-full object-cover object-top transition duration-700 group-hover:scale-110"
          />
          <div class="absolute -left-16 top-0 h-full w-24 rotate-12 bg-white/20 blur-2xl opacity-0 transition duration-700 group-hover:translate-x-[340px] group-hover:opacity-100"></div>
        </div>

        <div class="relative -mt-14 sm:-mt-16 z-20 mx-3 sm:mx-4 h-[190px] sm:h-[200px] rounded-[1.5rem] sm:rounded-[1.7rem] border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(91,33,182,0.96),rgba(37,99,235,0.96))] p-5 sm:p-6 text-center shadow-xl transition duration-500 group-hover:shadow-[0_20px_60px_rgba(99,102,241,0.35)] flex flex-col justify-between">
          <div class="flex-1 flex flex-col items-center justify-center">
            <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight">Iftakharul Alam</h3>
            <p class="mt-3 text-xs sm:text-sm uppercase tracking-[0.18em] text-cyan-100">Frontend Developer</p>
          </div>

          <div class="mt-5 flex justify-center gap-3 opacity-100 sm:opacity-0 translate-y-0 sm:translate-y-4 transition duration-500 group-hover:opacity-100 group-hover:translate-y-0">
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#1877F2] transition">
              <i class="ri-facebook-fill"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-cyan-500 transition">
              <i class="ri-twitter-x-line"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#E1306C] transition">
              <i class="ri-instagram-line"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="group relative mx-auto w-full max-w-[420px] rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_20px_50px_rgba(15,23,42,0.28)] backdrop-blur-md transition duration-500 hover:-translate-y-3 hover:border-violet-400/40 hover:shadow-[0_20px_60px_rgba(139,92,246,0.20)] sm:col-span-2 xl:col-span-1">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></div>
          <img
            src="/team-3.jpg"
            alt="Dennis Jacobson"
            class="h-[320px] sm:h-[350px] md:h-[380px] w-full object-cover object-top transition duration-700 group-hover:scale-110"
          />
          <div class="absolute -left-16 top-0 h-full w-24 rotate-12 bg-white/20 blur-2xl opacity-0 transition duration-700 group-hover:translate-x-[340px] group-hover:opacity-100"></div>
        </div>

        <div class="relative -mt-14 sm:-mt-16 z-20 mx-3 sm:mx-4 h-[190px] sm:h-[200px] rounded-[1.5rem] sm:rounded-[1.7rem] border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(91,33,182,0.96),rgba(37,99,235,0.96))] p-5 sm:p-6 text-center shadow-xl transition duration-500 group-hover:shadow-[0_20px_60px_rgba(99,102,241,0.35)] flex flex-col justify-between">
          <div class="flex-1 flex flex-col items-center justify-center">
            <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight">Dennis Jacobson</h3>
            <p class="mt-3 text-xs sm:text-sm uppercase tracking-[0.18em] text-cyan-100">Backend Developer</p>
          </div>

          <div class="mt-5 flex justify-center gap-3 opacity-100 sm:opacity-0 translate-y-0 sm:translate-y-4 transition duration-500 group-hover:opacity-100 group-hover:translate-y-0">
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#1877F2] transition">
              <i class="ri-facebook-fill"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-cyan-500 transition">
              <i class="ri-twitter-x-line"></i>
            </a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-[#E1306C] transition">
              <i class="ri-instagram-line"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



<script>
  import { initMobileMenu, initParticles } from '../scripts/main.js';
  document.addEventListener('DOMContentLoaded', () => {
    initMobileMenu();
    initParticles();
  });
</script>
</Layout>