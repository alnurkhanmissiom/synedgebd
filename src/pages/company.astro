---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SynEdge BD - Web Development, SEO, and Creative Solutions in Bangladesh" description= "SynEdge BD offers expert web development, SEO optimization, digital marketing, and creative services to help businesses in Bangladesh grow and succeed online.">


  <!-- ===== About Section ===== -->
  <section id="about" class="bg-[linear-gradient(180deg,#020617_0%,#0f172a_100%)] py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="inline-flex rounded-full border border-violet-400/20 bg-violet-400/10 px-4 py-2 text-sm font-semibold text-violet-300">
          ABOUT SYNEDGE BD
        </span>
        <h2 class="mt-5 text-4xl font-bold leading-tight md:text-5xl">
          A Bangladesh-based digital agency focused on performance, clarity, and measurable growth.
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-400">
          We combine strategy, design, and technology to help businesses expand their reach online.
          Every solution is built for speed, scalability, and real results.
        </p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
            <div class="text-2xl text-cyan-300">
              <i class="ri-rocket-2-line"></i>
            </div>
            <h3 class="mt-3 text-xl font-bold">Fast Execution</h3>
            <p class="mt-2 text-slate-400">
              Lean production, strong systems, and clear milestones.
            </p>
          </div>

          <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
            <div class="text-2xl text-amber-300">
              <i class="ri-bar-chart-box-line"></i>
            </div>
            <h3 class="mt-3 text-xl font-bold">Growth Driven</h3>
            <p class="mt-2 text-slate-400">
              Everything we build is aligned with outcomes and KPIs.
            </p>
          </div>
        </div>
      </div>

      <div class="relative h-[420px] sm:h-[500px]">
        <div class="absolute inset-0 rounded-[2rem] border border-white/10 bg-gradient-to-br from-cyan-400/10 via-violet-500/10 to-amber-400/10"></div>
        <div class="absolute inset-8 overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900/70 shadow-[0_25px_60px_rgba(2,6,23,0.35)]">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.18),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.18),transparent_30%)]"></div>
          <div class="absolute left-1/2 top-1/2 h-52 w-52 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle_at_30%_30%,rgba(34,211,238,0.9),rgba(59,130,246,0.5)_30%,rgba(76,29,149,0.82)_65%,rgba(2,6,23,0.96)_80%)] shadow-[0_0_70px_rgba(34,211,238,0.18)]"></div>
          <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full border border-cyan-400/20 animate-[spin_28s_linear_infinite]"></div>

          <div class="absolute inset-x-10 bottom-10 rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-md">
            <div class="text-sm uppercase tracking-[0.2em] text-cyan-300">Performance Snapshot</div>
            <div class="mt-3 grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold">4X</div>
                <div class="text-sm text-slate-400">Traffic</div>
              </div>
              <div>
                <div class="text-2xl font-bold">2.8X</div>
                <div class="text-sm text-slate-400">Leads</div>
              </div>
              <div>
                <div class="text-2xl font-bold">98%</div>
                <div class="text-sm text-slate-400">Speed</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

    <!-- --- About SynEdge BD Section --- -->
    <section class="about-us">
        <div class="container">
            <div class="about-content">
                <h2>About SynEdge BD</h2>
                <p>SynEdge BD is a **Bangladesh-based digital agency** dedicated to delivering impactful web and marketing solutions. Our team of experts merges **technology and creativity** to help businesses not just exist online, but truly expand their reach and dominate their market. We pride ourselves on a collaborative approach, ensuring every solution is tailored and drives tangible results for our clients globally.</p>
                <a href="#" class="btn-secondary">Meet the Team</a>
            </div>
            <div class="about-stats">
                <div class="stat-card"><span>5+</span><p>Years in Business</p></div>
                <div class="stat-card"><span>150+</span><p>Successful Projects</p></div>
                <div class="stat-card"><span>95%</span><p>Client Satisfaction</p></div>
            </div>
        </div>
    </section>






<!-- ===== Recent Projects Section ===== -->
<section id="projects" class="relative overflow-hidden bg-slate-950 py-20 sm:py-24 px-4 sm:px-6 lg:px-8">

  <!-- Background Glow -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.10),transparent_25%),radial-gradient(circle_at_bottom_right,rgba(139,92,246,0.15),transparent_30%)]"></div>

  <div class="relative max-w-7xl mx-auto">

    <!-- Heading -->
    <div class="text-center mb-14 sm:mb-16">
      <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-300">
        RECENT PROJECTS
      </span>
      <h2 class="mt-5 text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Our Latest <span class="text-cyan-400">Work</span>
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-7 text-slate-400">
        A showcase of our recent digital experiences, built with performance, creativity, and precision.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">

      <!-- Project Card -->
      <div class="group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-md shadow-[0_20px_50px_rgba(15,23,42,0.28)] transition duration-500 hover:-translate-y-3 hover:border-cyan-400/40 hover:shadow-[0_20px_60px_rgba(34,211,238,0.18)]">
        
        <!-- Image -->
        <div class="relative overflow-hidden">
          <img src="./project-1.webp" class="w-full h-[260px] sm:h-[300px] object-cover transition duration-700 group-hover:scale-110" />
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>

          <!-- Hover Content -->
          <div class="absolute bottom-6 left-6 right-6 opacity-0 translate-y-6 group-hover:opacity-100 group-hover:translate-y-0 transition duration-500">
            <a href="https://www.applegadgetsbd.com/" class="inline-block bg-white text-slate-900 px-5 py-2 rounded-full text-sm font-semibold hover:scale-105 transition">
              View Project →
            </a>
          </div>
        </div>

        <!-- Content -->
        <div class="p-6">
          <h3 class="text-xl sm:text-2xl font-bold text-white">E-Commerce Website</h3>
          <p class="mt-3 text-slate-400 text-sm sm:text-base">
            High-converting online store with modern UI, fast performance, and secure checkout.
          </p>
        </div>
      </div>

      <!-- Project Card -->
      <div class="group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-md shadow-[0_20px_50px_rgba(15,23,42,0.28)] transition duration-500 hover:-translate-y-3 hover:border-violet-400/40 hover:shadow-[0_20px_60px_rgba(139,92,246,0.20)]">
        
        <div class="relative overflow-hidden">
          <img src="./project-2.webp" class="w-full h-[260px] sm:h-[300px] object-cover transition duration-700 group-hover:scale-110" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>

          <div class="absolute bottom-6 left-6 right-6 opacity-0 translate-y-6 group-hover:opacity-100 group-hover:translate-y-0 transition duration-500">
            <a href="https://electronicsbangladesh.com/" class="inline-block bg-white text-slate-900 px-5 py-2 rounded-full text-sm font-semibold hover:scale-105 transition">
              View Project →
            </a>
          </div>
        </div>

        <div class="p-6">
          <h3 class="text-xl sm:text-2xl font-bold text-white">SEO Optimization Project</h3>
          <p class="mt-3 text-slate-400 text-sm sm:text-base">
            Boosted organic traffic and ranking using advanced SEO strategies.
          </p>
        </div>
      </div>

      <!-- Project Card -->
      <div class="group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-md shadow-[0_20px_50px_rgba(15,23,42,0.28)] transition duration-500 hover:-translate-y-3 hover:border-amber-400/40 hover:shadow-[0_20px_60px_rgba(245,158,11,0.20)]">
        
        <div class="relative overflow-hidden">
          <img src="./project-3.avif" class="w-full h-[260px] sm:h-[300px] object-cover transition duration-700 group-hover:scale-110" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>

          <div class="absolute bottom-6 left-6 right-6 opacity-0 translate-y-6 group-hover:opacity-100 group-hover:translate-y-0 transition duration-500">
            <a href="#" class="inline-block bg-white text-slate-900 px-5 py-2 rounded-full text-sm font-semibold hover:scale-105 transition">
              View Project →
            </a>
          </div>
        </div>

        <div class="p-6">
          <h3 class="text-xl sm:text-2xl font-bold text-white">Creative Branding</h3>
          <p class="mt-3 text-slate-400 text-sm sm:text-base">
            Complete brand identity design with modern visuals and UX-focused approach.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>






  <!-- --- CTA Section --- -->
<section class="relative overflow-hidden py-20 sm:py-24 px-4 sm:px-6 lg:px-8 bg-slate-950">
  <!-- Background gradients -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_24%),radial-gradient(circle_at_top_right,rgba(139,92,246,0.18),transparent_28%),radial-gradient(circle_at_bottom_center,rgba(245,158,11,0.10),transparent_24%),linear-gradient(135deg,#0f172a_0%,#1e1b4b_50%,#020617_100%)]"></div>

  <!-- Grid texture -->
  <div class="absolute inset-0 opacity-[0.06] bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:42px_42px]"></div>

  <!-- 3D animated glows -->
  <div class="pointer-events-none absolute -left-20 top-10 h-72 w-72 rounded-full bg-cyan-400/20 blur-3xl animate-pulse"></div>
  <div class="pointer-events-none absolute right-0 top-0 h-80 w-80 rounded-full bg-violet-500/20 blur-3xl animate-pulse"></div>
  <div class="pointer-events-none absolute left-1/3 bottom-0 h-72 w-72 rounded-full bg-amber-400/10 blur-3xl animate-pulse"></div>

  <!-- 3D rings -->
  <div class="pointer-events-none absolute left-10 top-1/2 hidden -translate-y-1/2 xl:block">
    <div class="relative h-56 w-56">
      <div class="absolute inset-0 rounded-full border border-cyan-400/20 animate-[spin_18s_linear_infinite]"></div>
      <div class="absolute inset-6 rounded-full border border-violet-400/20 animate-[spin_14s_linear_infinite_reverse]"></div>
      <div class="absolute inset-14 rounded-full bg-[radial-gradient(circle_at_30%_30%,rgba(34,211,238,0.9),rgba(59,130,246,0.5)_30%,rgba(76,29,149,0.72)_60%,rgba(2,6,23,0.95)_80%)] shadow-[0_0_60px_rgba(34,211,238,0.18)]"></div>
    </div>
  </div>

  <div class="pointer-events-none absolute right-10 top-1/2 hidden -translate-y-1/2 xl:block">
    <div class="relative h-44 w-44">
      <div class="absolute inset-0 rounded-full border border-amber-400/20 animate-[spin_20s_linear_infinite]"></div>
      <div class="absolute inset-8 rounded-full border border-white/10 animate-[spin_12s_linear_infinite_reverse]"></div>
      <div class="absolute inset-16 rounded-full bg-[radial-gradient(circle_at_center,rgba(245,158,11,0.8),rgba(236,72,153,0.4),transparent_75%)] blur-md"></div>
    </div>
  </div>

  <div class="relative max-w-5xl mx-auto">
    <div class="rounded-[2rem] border border-white/10 bg-white/10 backdrop-blur-xl shadow-[0_25px_60px_rgba(2,6,23,0.35)] px-6 sm:px-10 lg:px-14 py-12 sm:py-14 text-center">
      <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-300">
        LET’S BUILD SOMETHING POWERFUL
      </span>

      <h2 class="mt-6 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight text-white">
        Ready to Expand Your
        <span class="bg-gradient-to-r from-cyan-300 via-white to-fuchsia-300 bg-clip-text text-transparent">
          Digital Footprint?
        </span>
      </h2>

      <p class="mt-5 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-7 sm:leading-8 text-slate-300">
        Let SynEdge BD provide the edge you need in web development, SEO, marketing, and creative design.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-bold text-slate-900 shadow-xl transition duration-300 hover:scale-105"
        >
          <span>Start a Project Today</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-violet-100 text-violet-700">
            ↗
          </span>
        </a>

        <a
          href="#"
          class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-7 py-3.5 text-base font-semibold text-white transition duration-300 hover:border-cyan-300/50 hover:bg-white/15"
        >
          Book a Free Consultation
        </a>
      </div>
    </div>
  </div>
</section>
</Layout>